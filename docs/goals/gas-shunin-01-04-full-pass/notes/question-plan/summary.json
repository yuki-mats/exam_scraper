    "suggestedQuestions": [
      "平板の定常熱伝導で熱流束を求める式は？",
      "この問題の温度差ΔTはいくつか？",
      "q=λΔT/Lに数値を代入するといくつか？",
      "厚さ0.3mは式の分子と分母のどちらに入るか？",
      "20W/m²以外の選択肢が不適切な理由は？"
    ],
    "suggestedQuestionDetails": [
      {
        "question": "平板の定常熱伝導で熱流束を求める式は？",
        "answer": "q=λΔT/L。",
        "explanation": "平板の定常熱伝導では、熱流束は熱伝導率と温度差に比例し、厚さに反比例する。"
      },
      {
        "question": "この問題の温度差ΔTはいくつか？",
        "answer": "60K。",
        "explanation": "高温側20℃、低温側-40℃なので、温度差は20-(-40)=60Kである。"
      },
      {
        "question": "q=λΔT/Lに数値を代入するといくつか？",
        "answer": "20W/m²。",
        "explanation": "正解。平板の定常熱伝導の熱流束は q=λΔT/L。平均熱伝導率0.1W/(m·K)、温度差60K、厚さ0.3mより q=0.1×60/0.3=20W/m²となる。"
      },
      {
        "question": "厚さ0.3mは式の分子と分母のどちらに入るか？",
        "answer": "分母に入る。",
        "explanation": "熱流束は厚さに反比例するため、L=0.3mは分母に入る。"
      },
      {
        "question": "20W/m²以外の選択肢が不適切な理由は？",
        "answer": "式から得られる20W/m²と一致しないため。",
        "explanation": "与えられた条件では q=0.1×60/0.3=20W/m²であり、他の選択肢は計算結果に合わない。"
      }
    ],
