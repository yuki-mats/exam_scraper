    "suggestedQuestionDetails": [
      {
        "question": "質量流量・密度・断面積・平均流速の関係式は？",
        "answer": "m=ρAv を用いる。",
        "explanation": "密度ρ、断面積A、平均流速vの積が質量流量になる。"
      },
      {
        "question": "本問の断面積Aはいくらか？",
        "answer": "A=3.14/(1×4)=0.785m²。",
        "explanation": "m=ρAv を A=m/(ρv) に変形して代入する。"
      },
      {
        "question": "直円管の断面積Aから内径Dをどう求める？",
        "answer": "A=πD²/4 より D=√(4A/π)。",
        "explanation": "円管の断面積式を内径Dについて解く。"
      },
      {
        "question": "本問の内径Dはいくらか？",
        "answer": "D=1.0m。",
        "explanation": "D=√(4×0.785/3.14)=√1=1.0mとなる。"
      },
      {
        "question": "1.5m以上の選択肢が不正解になる理由は？",
        "answer": "同じ密度・平均流速では質量流量が3.14kg/sを超えるため。",
        "explanation": "内径が大きいほど断面積が大きくなり、m=ρAvも大きくなる。"
      }
    ],
