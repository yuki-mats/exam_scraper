            <ItemSentence>
              <Column Num="1">
                <Sentence Num="1" WritingMode="vertical">沿道地区計画</Sentence>
              </Column>
              <Column Num="2">
                <Sentence Num="1" WritingMode="vertical">都市計画法第十二条の四第一項第四号に掲げる沿道地区計画をいう。</Sentence>
              </Column>
            </ItemSentence>
          </Item>
          <Item Num="30">
            <ItemTitle>三十</ItemTitle>
            <ItemSentence>
              <Column Num="1">
                <Sentence Num="1" WritingMode="vertical">沿道地区整備計画</Sentence>
              </Column>
              <Column Num="2">
                <Sentence Num="1" WritingMode="vertical">幹線道路の沿道の整備に関する法律（昭和五十五年法律第三十四号。以下「沿道整備法」という。）第九条第二項第一号に掲げる沿道地区整備計画をいう。</Sentence>
              </Column>
            </ItemSentence>
          </Item>
          <Item Num="31">
