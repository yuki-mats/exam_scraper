              </Column>
              <Column Num="2">
                <Sentence Num="1" WritingMode="vertical">密集市街地整備法第三十二条第二項第二号に規定する防災街区整備地区整備計画をいう。</Sentence>
              </Column>
            </ItemSentence>
          </Item>
