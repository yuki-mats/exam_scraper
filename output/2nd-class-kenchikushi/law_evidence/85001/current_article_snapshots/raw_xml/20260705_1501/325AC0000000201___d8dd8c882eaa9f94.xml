              </Column>
              <Column Num="2">
                <Sentence Num="1" WritingMode="vertical">都市計画法第十二条の四第一項第五号に掲げる集落地区計画をいう。</Sentence>
              </Column>
            </ItemSentence>
          </Item>
          <Item Num="32">
            <ItemTitle>三十二</ItemTitle>
