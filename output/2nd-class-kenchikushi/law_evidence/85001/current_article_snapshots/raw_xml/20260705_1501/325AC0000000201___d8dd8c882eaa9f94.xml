            <ItemTitle>二十七</ItemTitle>
            <ItemSentence>
              <Column Num="1">
                <Sentence Num="1" WritingMode="vertical">歴史的風致維持向上地区計画</Sentence>
              </Column>
              <Column Num="2">
                <Sentence Num="1" WritingMode="vertical">都市計画法第十二条の四第一項第三号に掲げる歴史的風致維持向上地区計画をいう。</Sentence>
              </Column>
            </ItemSentence>
          </Item>
