{"schemaVersion": "gas-shunin-primary-evidence-snapshot/v1", "generatedAt": "2026-07-09T23:59:59+09:00", "qualification": "gas-shunin-kou", "examYear": 2022, "questionLabel": "問24", "displayQuestionId": "gasushunin-koushu-gizyutsu-2022-24", "reviewQuestionId": "firestore:chiefgasengineerlicense-A-60-1235,chiefgasengineerlicense-A-60-1236,chiefgasengineerlicense-A-60-1237,chiefgasengineerlicense-A-60-1238,chiefgasengineerlicense-A-60-1239", "queueSequence": 267, "choiceIndex": 2, "choiceText": "BF-C式機器のチャンバーは、外気に開放された廊下で、給排気口が風による渦流や風圧差等によらず、逆流の生じない位置及び構造とする。", "correctChoiceText": "正しい", "verdict": "correct", "explanationText": "正しい。BF-C式機器のチャンバーは外気に開放された廊下で、給排気口は外気の流れや風圧差等によって給排気が妨げられず、逆流が生じない位置及び構造とする必要がある。", "sourceVariant": "firestore_statement_set", "source": "egov_xml", "referenceDate": "2026-07-09", "lawId": "345M50000400097", "lawTitle": "ガス事業法施行規則", "lawAlias": "ガス則", "article": "202", "articleTitle": "消費機器の技術上の基準", "paragraph": "1", "item": "6", "subitem": "ホ・ヘ・ヌ", "relation": "direct_basis", "primaryBasis": true, "apiUrl": "https://laws.e-gov.go.jp/api/1/articles;lawId=345M50000400097;article=202", "rawXmlPath": "output/gas-shunin-all/review/primary_law_evidence/raw_xml/20260709_235959_q24/345M50000400097_202_cf8dcd0498d0f4d5.xml", "rawXmlHash": "cf8dcd0498d0f4d5d0fad41a0ce3fa47385ca881efb015a4407341904a9bdd5f", "articleTextHash": "418cf5c41f4d90738fc853a6224a525412baef5c610ea19f79de8518d97c2847", "promptContext": "密閉燃焼式機器の給排気部先端は、障害物又は外気の流れ等で給排気が妨げられない位置・構造とし、燃焼が妨げられない風量を確保する必要がある。", "lawzillaReconciliation": {"status": "reconciled_no_hit_to_framework", "note": "Lawzilla候補は0件だったため、BF-C式の給排気部基準として施行規則第202条第1項第6号ホ・ヘ・ヌを直接確認した。"}, "supplementalTechnicalEvidence": []}
{"schemaVersion": "gas-shunin-primary-evidence-snapshot/v1", "generatedAt": "2026-07-09T23:59:59+09:00", "qualification": "gas-shunin-kou", "examYear": 2022, "questionLabel": "問24", "displayQuestionId": "gasushunin-koushu-gizyutsu-2022-24", "reviewQuestionId": "firestore:chiefgasengineerlicense-A-60-1235,chiefgasengineerlicense-A-60-1236,chiefgasengineerlicense-A-60-1237,chiefgasengineerlicense-A-60-1238,chiefgasengineerlicense-A-60-1239", "queueSequence": 267, "choiceIndex": 3, "choiceText": "CF式機器の排気筒トップは、排気筒トップから水平方向1ｍ以内に軒のある建物が隣接する場合、その隣接する建物の軒から300㎜以上高くする必要がある。", "correctChoiceText": "間違い", "verdict": "incorrect", "explanationText": "間違い。CF式機器の排気筒トップは、トップから水平方向1m以内に軒のある建物が隣接する場合、隣接建物の軒から600㎜以上高くする必要がある。300㎜以上としている点が誤り。", "sourceVariant": "firestore_statement_set", "source": "egov_xml", "referenceDate": "2026-07-09", "lawId": "345M50000400097", "lawTitle": "ガス事業法施行規則", "lawAlias": "ガス則", "article": "202", "articleTitle": "消費機器の技術上の基準", "paragraph": "1", "item": "2", "subitem": "イ（5）・イ（7）", "relation": "legal_framework", "primaryBasis": true, "apiUrl": "https://laws.e-gov.go.jp/api/1/articles;lawId=345M50000400097;article=202", "rawXmlPath": "output/gas-shunin-all/review/primary_law_evidence/raw_xml/20260709_235959_q24/345M50000400097_202_cf8dcd0498d0f4d5.xml", "rawXmlHash": "cf8dcd0498d0f4d5d0fad41a0ce3fa47385ca881efb015a4407341904a9bdd5f", "articleTextHash": "418cf5c41f4d90738fc853a6224a525412baef5c610ea19f79de8518d97c2847", "promptContext": "自然排気式の燃焼器の排気筒について、先端が障害物又は外気の流れによって排気を妨げられない位置にあること、及び高さが所定式で算出した値以上であることを定めている。600㎜の寸法自体はe-Gov施行規則本文には現れないため、設置基準・実務資料で補完確認する。", "lawzillaReconciliation": {"status": "reconciled_to_technical_standard_with_supplement", "note": "Lawzilla候補は施行規則第197条・第200条及び第202条周辺に寄った。e-Gov上は第202条第1項第2号イの自然排気式排気筒基準を法令枠として確認し、600㎜寸法は消防庁通知等の設置基準で補完確認した。"}, "supplementalTechnicalEvidence": [{"choiceIndex": 3, "sourceLabel": "消防庁通知 業務用ガス機器の設置基準の改正について", "sourceUrl": "https://www.fdma.go.jp/laws/tutatsu/assets/070731yo167.pdf", "use": "排気筒トップと軒との関係で60cm以上高くする基準を補完確認。", "authority": "official_fire_and_disaster_management_agency_notice"}]}
{"schemaVersion": "gas-shunin-primary-evidence-snapshot/v1", "generatedAt": "2026-07-09T23:59:59+09:00", "qualification": "gas-shunin-kou", "examYear": 2022, "questionLabel": "問24", "displayQuestionId": "gasushunin-koushu-gizyutsu-2022-24", "reviewQuestionId": "firestore:chiefgasengineerlicense-A-60-1235,chiefgasengineerlicense-A-60-1236,chiefgasengineerlicense-A-60-1237,chiefgasengineerlicense-A-60-1238,chiefgasengineerlicense-A-60-1239", "queueSequence": 267, "choiceIndex": 4, "choiceText": "FE式機器では、排気筒の横引き長さと高さとの関係に関する法令上の規定はない。", "correctChoiceText": "正しい", "verdict": "correct", "explanationText": "正しい。FE式機器は送風機で強制的に排気する方式であり、現行の消費機器技術基準では、自然排気式の排気筒に置かれている横引き長さと高さの関係式は、強制排気式の排気筒には準用されていない。したがって、排気筒の横引き長さと高さとの関係に関する規定はない。", "sourceVariant": "firestore_statement_set", "source": "egov_xml", "referenceDate": "2026-07-09", "lawId": "345M50000400097", "lawTitle": "ガス事業法施行規則", "lawAlias": "ガス則", "article": "202", "articleTitle": "消費機器の技術上の基準", "paragraph": "1", "item": "2", "subitem": "ロ（1）", "relation": "direct_basis", "primaryBasis": true, "apiUrl": "https://laws.e-gov.go.jp/api/1/articles;lawId=345M50000400097;article=202", "rawXmlPath": "output/gas-shunin-all/review/primary_law_evidence/raw_xml/20260709_235959_q24/345M50000400097_202_cf8dcd0498d0f4d5.xml", "rawXmlHash": "cf8dcd0498d0f4d5d0fad41a0ce3fa47385ca881efb015a4407341904a9bdd5f", "articleTextHash": "418cf5c41f4d90738fc853a6224a525412baef5c610ea19f79de8518d97c2847", "promptContext": "強制排気式の燃焼器の排気筒は、自然排気式の基準のうちイ（1）、（4）、（5）の障害物部分、（6）の異物侵入部分、（8）及びイ（9）に適合するものとされ、自然排気式の高さ計算式であるイ（7）は準用されていない。", "lawzillaReconciliation": {"status": "matched_but_needed_locator_detail", "note": "Lawzilla候補の第202条第1項第2号ロを確認し、強制排気式には自然排気式の高さ計算式イ（7）が準用されないことを条項構造で確認した。"}, "supplementalTechnicalEvidence": []}
