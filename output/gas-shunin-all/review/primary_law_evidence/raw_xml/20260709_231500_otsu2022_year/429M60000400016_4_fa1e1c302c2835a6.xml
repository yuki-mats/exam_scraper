                <TableColumn BorderBottom="solid" BorderLeft="solid" BorderRight="solid" BorderTop="solid">
                  <Sentence Num="1" WritingMode="vertical">当該事故に係る消費機器又はガス栓の設置の場所を管轄する産業保安監督部長</Sentence>
                </TableColumn>
              </TableRow>
