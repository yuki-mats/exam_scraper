    <LawContents>
      <Article Num="48">
        <ArticleCaption>（定期自主検査）</ArticleCaption>
        <ArticleTitle>第四十八条</ArticleTitle>
        <Paragraph Num="1">
          <ParagraphNum/>
          <ParagraphSentence>
            <Sentence Num="1" WritingMode="vertical">法第三十四条の経済産業省令で定めるガス工作物は、次に掲げるガス工作物（不活性のガス（空気を含む。）又は不活性の液化ガスのみを通ずるもの及び電気事業法が適用されるものを除く。）であつて、最高使用圧力が高圧のものとする。</Sentence>
          </ParagraphSentence>
          <Item Num="1">
            <ItemTitle>一</ItemTitle>
            <ItemSentence>
              <Sentence Num="1" WritingMode="vertical">ガス発生設備（移動式ガス発生設備及び液化石油ガスを気化してガスを発生させる設備（気化したガスの出口部分の最高使用圧力が高圧であるもの以外のものに限る。）を除く。）、ガス精製設備、ガスホルダー、熱交換器、冷凍設備（小型、ユニット型又は冷媒ガスが不活性のものを除く。）、導管及び整圧器</Sentence>
            </ItemSentence>
          </Item>
          <Item Num="2">
            <ItemTitle>二</ItemTitle>
            <ItemSentence>
              <Sentence Num="1" WritingMode="vertical">熱量調整装置に属する容器又は付臭剤を収納する容器</Sentence>
            </ItemSentence>
          </Item>
        </Paragraph>
        <Paragraph Num="2">
          <ParagraphNum>２</ParagraphNum>
          <ParagraphSentence>
            <Sentence Num="1" WritingMode="vertical">法第三十四条の自主検査は、次に掲げる方法で行うものとする。</Sentence>
          </ParagraphSentence>
          <Item Num="1">
            <ItemTitle>一</ItemTitle>
            <ItemSentence>
              <Sentence Num="1" WritingMode="vertical">開放、分解その他の各部の損傷、変形及び異常の発生状況を確認するために十分な方法</Sentence>
            </ItemSentence>
          </Item>
          <Item Num="2">
            <ItemTitle>二</ItemTitle>
            <ItemSentence>
              <Sentence Num="1" WritingMode="vertical">試運転その他の機能及び作動の状況を確認するために十分な方法</Sentence>
            </ItemSentence>
          </Item>
        </Paragraph>
      </Article>
    </LawContents>
