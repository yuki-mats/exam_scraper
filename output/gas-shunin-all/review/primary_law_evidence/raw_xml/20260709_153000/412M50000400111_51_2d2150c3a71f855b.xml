          </Item>
          <Item Num="2">
            <ItemTitle>二</ItemTitle>
            <ItemSentence>
              <Column Num="1">
                <Sentence Num="1" WritingMode="vertical">第二項の表（１）に規定する検査</Sentence>
              </Column>
              <Column Num="2">
                <Sentence Num="1" WritingMode="vertical">六年</Sentence>
              </Column>
            </ItemSentence>
          </Item>
          <Item Num="3">
            <ItemTitle>三</ItemTitle>
            <ItemSentence>
              <Column Num="1">
                <Sentence Num="1" WritingMode="vertical">第一項の表（３）、第二項の表（３）に規定する検査</Sentence>
              </Column>
              <Column Num="2">
