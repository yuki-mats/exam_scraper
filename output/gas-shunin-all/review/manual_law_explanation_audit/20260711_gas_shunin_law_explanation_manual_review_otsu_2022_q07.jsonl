{"schemaVersion":"gas-shunin-manual-law-explanation-audit/v1","reviewedAt":"2026-07-11","qualification":"gas-shunin-otsu","examYear":2022,"sourceQuestionKey":"gas-shunin:otsu:2022:law:q07","questionLabel":"問7","sourceQuestionBodyText":"技術基準で規定されているガス工作物に関する次の記述のうち、いずれも誤っているものの組合せはどれか。","sourceFile":"output/gas-shunin-otsu/questions_json/2022/00_source/question_2022_1.json","explanationPatchFile":"output/gas-shunin-otsu/questions_json/2022/21_explanationText_added/question_2022_1_explanationText_added.json","sourceCorrectChoiceText":["間違い","間違い","正しい","正しい","正しい"],"patchedCorrectChoiceText":["間違い","間違い","正しい","正しい","正しい"],"correctChoiceTextMatchesSource":true,"choiceReviews":[{"choiceIndex":0,"verdict":"間違い","directBasis":["ガス工作物の技術上の基準を定める省令第6条第2項"],"basisText":"離隔距離は容器の外面から保安物件に対して確保する。"},{"choiceIndex":1,"verdict":"間違い","directBasis":["同省令第8条"],"basisText":"防消火設備はガスの種類ではなく規模に応じて設ける。"},{"choiceIndex":2,"verdict":"正しい","directBasis":["同省令第9条第2項"],"basisText":"製造所には漏えい検知・警報設備を設ける。"},{"choiceIndex":3,"verdict":"正しい","directBasis":["同省令第10条"],"basisText":"電気設備には設置場所とガス種に応じた防爆性能が必要である。"},{"choiceIndex":4,"verdict":"正しい","directBasis":["同省令第12条"],"basisText":"液化ガス設備には静電気除去措置を講じ、引火おそれがない場合は例外である。"}],"changedFields":[],"result":"reviewed_no_explanation_change_needed","sourceUrls":["https://laws.e-gov.go.jp/law/412M50000400111"]}
