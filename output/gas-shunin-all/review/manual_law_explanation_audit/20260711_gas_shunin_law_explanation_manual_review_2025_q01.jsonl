{"schemaVersion":"gas-shunin-manual-law-explanation-audit/v1","reviewedAt":"2026-07-11","qualification":"gas-shunin-kou","examYear":2025,"sourceQuestionKey":"gas-shunin:kou:2025:law:q01","questionLabel":"問1","sourceFile":"output/gas-shunin-kou/questions_json/2025/00_source/question_2025_gassyunin_site_1.json","explanationPatchFile":"output/gas-shunin-kou/questions_json/2025/21_explanationText_added/question_2025_gassyunin_site_1_explanationText_added.json","sourceCorrectChoiceText":["間違い","正しい","間違い","間違い","間違い"],"patchedCorrectChoiceText":["間違い","正しい","間違い","間違い","間違い"],"correctChoiceTextMatchesSource":true,"choiceReviews":[{"choiceIndex":0,"verdict":"間違い","directBasis":["ガス事業法第2条第1項"],"basisText":"特定ガス発生設備による小売供給は、一の団地内の供給地点数が七十以上のものに限る。"},{"choiceIndex":1,"verdict":"正しい","directBasis":["ガス事業法第2条第13項"],"basisText":"ガス工作物は、ガス供給のために施設する工作物及び附属設備であって、ガス事業の用に供するものをいう。"},{"choiceIndex":2,"verdict":"間違い","directBasis":["ガス事業法施行規則第1条第2項第4号"],"basisText":"熱量は、標準状態の乾燥したガス一立方メートル中で測定される総熱量をいう。"},{"choiceIndex":3,"verdict":"間違い","directBasis":["ガス事業法施行規則第1条第2項第5号"],"basisText":"液化ガスは、圧力が〇・二メガパスカルとなる場合の温度が三十五度以下である液化ガスを含む。"},{"choiceIndex":4,"verdict":"間違い","directBasis":["ガス事業法第175条"],"basisText":"高圧ガス保安法の該当規定は、ガス事業及びガス工作物について適用しない。"}],"changedFields":["explanationText","suggestedQuestionDetails","sourceExplanationCommonSummary"],"result":"reviewed_and_rewritten","sourceUrls":["https://laws.e-gov.go.jp/law/329AC0000000051","https://laws.e-gov.go.jp/law/345M50000400097"]}
