{"schemaVersion":"gas-shunin-manual-law-explanation-audit/v1","reviewedAt":"2026-07-11","qualification":"gas-shunin-kou","examYear":2022,"sourceQuestionKey":"gas-shunin:kou:2022:law:q03","questionLabel":"問3","sourceQuestionBodyText":"法令で規定されているガス工作物に関する次の記述のうち、正しいものはいくつあるか。","sourceFile":"output/gas-shunin-kou/questions_json/2022/00_source/question_2022_firestore_2.json","explanationPatchFile":"output/gas-shunin-kou/questions_json/2022/21_explanationText_added/question_2022_firestore_2_explanationText_added.json","sourceCorrectChoiceText":["間違い","正しい","間違い","間違い","間違い"],"patchedCorrectChoiceText":["間違い","正しい","間違い","間違い","間違い"],"correctChoiceTextMatchesSource":true,"choiceReviews":[{"choiceIndex":0,"verdict":"間違い","directBasis":["ガス事業法第21条第3項"],"basisText":"緊急命令は公共の安全維持又は災害発生防止のためである。"},{"choiceIndex":1,"verdict":"正しい","directBasis":["同法第22条第1項"],"basisText":"他者所有等のガス工作物の維持措置には協力努力義務がある。"},{"choiceIndex":2,"verdict":"間違い","directBasis":["同法第24条第1項"],"basisText":"保安規程は許可ではなく届出である。"},{"choiceIndex":3,"verdict":"間違い","directBasis":["ガス事業法施行規則第24条第1項第2号"],"basisText":"保安規程にはガス主任技術者の職務代行者を定める。"},{"choiceIndex":4,"verdict":"間違い","directBasis":["同法第160条第1項","同法施行規則第207条第1項"],"basisText":"消費機器の周知・調査は保安業務規程の事項である。"}],"changedFields":["explanationText"],"result":"reviewed_and_rewritten","sourceUrls":["https://laws.e-gov.go.jp/law/329AC0000000051","https://laws.e-gov.go.jp/law/345M50000400097"]}
