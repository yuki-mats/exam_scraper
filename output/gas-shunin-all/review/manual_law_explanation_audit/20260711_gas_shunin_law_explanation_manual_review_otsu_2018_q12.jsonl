{"schemaVersion":"gas-shunin-manual-law-explanation-audit/v1","reviewedAt":"2026-07-11","qualification":"gas-shunin-otsu","examYear":2018,"sourceQuestionKey":"gas-shunin:otsu:2018:law:q12","questionLabel":"問12","sourceQuestionBodyText":"漏えい検査及び整圧器に関する次の行為のうち、技術基準に適合していないものはいくつあるか。ただし、イとロについては漏えい検査を行う区間に漏えい検知装置を設置していないものとする。","sourceFile":"output/gas-shunin-otsu/questions_json/2018/00_source/question_2018_1.json","explanationPatchFile":"output/gas-shunin-otsu/questions_json/2018/21_explanationText_added/question_2018_1_explanationText_added.json","sourceCorrectChoiceText":["正しい","間違い","間違い","正しい","正しい"],"patchedCorrectChoiceText":["正しい","間違い","間違い","正しい","正しい"],"correctChoiceTextMatchesSource":true,"choiceReviews":[{"choiceIndex":0,"verdict":"正しい","directBasis":["ガス工作物の技術上の基準を定める省令第51条第2項表"],"basisText":"特定管理管でない対象部分は4年に1回以上の漏えい検査を要する。"},{"choiceIndex":1,"verdict":"間違い","directBasis":["同省令第51条第3項表"],"basisText":"特定地下街等供給導管は1年に1回以上であり、6年ではない。"},{"choiceIndex":2,"verdict":"間違い","directBasis":["同省令第51条第4項"],"basisText":"基準日前4月以内の検査を基準日に行ったものとみなす。"},{"choiceIndex":3,"verdict":"正しい","directBasis":["同省令第58条第2項"],"basisText":"浸水のおそれがある地下の整圧器に浸水防止措置を要する。"},{"choiceIndex":4,"verdict":"正しい","directBasis":["同省令第59条"],"basisText":"整圧器の制御配管等を耐震支持する。"}],"changedFields":[],"result":"reviewed_no_explanation_change_needed","sourceUrls":["https://laws.e-gov.go.jp/law/412M50000400111"]}
