{"schemaVersion":"gas-shunin-manual-law-explanation-audit/v1","reviewedAt":"2026-07-11","qualification":"gas-shunin-kou","examYear":2023,"sourceQuestionKey":"gas-shunin:kou:2023:law:q03","questionLabel":"問3","sourceFile":"output/gas-shunin-kou/questions_json/2023/00_source/question_2023_firestore_2.json","explanationPatchFile":"output/gas-shunin-kou/questions_json/2023/21_explanationText_added/question_2023_firestore_2_explanationText_added.json","sourceCorrectChoiceText":["正しい","正しい","間違い","間違い","正しい"],"patchedCorrectChoiceText":["正しい","正しい","間違い","間違い","正しい"],"correctChoiceTextMatchesSource":true,"choiceReviews":[{"choiceIndex":0,"verdict":"正しい","directBasis":["ガス事業法第61条第1項"],"basisText":"一般ガス導管事業者は、その用に供するガス工作物を技術上の基準に適合するよう維持しなければならない。"},{"choiceIndex":1,"verdict":"正しい","directBasis":["ガス事業法第62条第1項"],"basisText":"他者が所有又は占有するガス工作物について、所有者又は占有者は維持措置の実施に協力するよう努めなければならない。"},{"choiceIndex":2,"verdict":"間違い","directBasis":["ガス事業法第64条第1項"],"basisText":"保安規程は、事業又は所定工事の開始前に経済産業大臣へ届け出るものであり、許可を受けるものではない。"},{"choiceIndex":3,"verdict":"間違い","directBasis":["ガス事業法施行規則第92条第1項"],"basisText":"保安規程の必須記載事項に、経済産業省との連携協力に関する事項はない。","basisAlignmentReviewStatus":"verified_current_basis","basisAlignmentReviewedAt":"2026-07-11","basisAlignmentReviewedDirectBasis":["ガス事業法施行規則第92条第1項"],"basisAlignmentReviewReason":"e-Gov本文と事業類型を照合し、類似条文候補は誤検知と確認"},{"choiceIndex":4,"verdict":"正しい","directBasis":["ガス事業法施行規則第92条第1項第八号"],"basisText":"導管の工事現場の責任者の条件その他保安監督体制は、保安規程の必須記載事項である。"}],"changedFields":["explanationText","suggestedQuestionDetails","sourceExplanationCommonSummary","sourceExplanationChoiceSnippets"],"result":"reviewed_and_rewritten","sourceUrls":["https://laws.e-gov.go.jp/law/329AC0000000051","https://laws.e-gov.go.jp/law/345M50000400097"]}
