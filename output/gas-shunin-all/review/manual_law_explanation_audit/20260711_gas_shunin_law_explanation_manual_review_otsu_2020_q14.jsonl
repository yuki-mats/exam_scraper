{"schemaVersion":"gas-shunin-manual-law-explanation-audit/v1","reviewedAt":"2026-07-11","qualification":"gas-shunin-otsu","examYear":2020,"sourceQuestionKey":"gas-shunin:otsu:2020:law:q14","questionLabel":"問14","sourceQuestionBodyText":"法令で規定されている保安業務規程に関する記述のうち、いずれも誤っているものの組合せはどれか。","sourceFile":"output/gas-shunin-otsu/questions_json/2020/00_source/question_2020_1.json","explanationPatchFile":"output/gas-shunin-otsu/questions_json/2020/21_explanationText_added/question_2020_1_explanationText_added.json","sourceCorrectChoiceText":["正しい","間違い","正しい","間違い","正しい"],"patchedCorrectChoiceText":["正しい","間違い","正しい","間違い","正しい"],"correctChoiceTextMatchesSource":true,"choiceReviews":[{"choiceIndex":0,"verdict":"正しい","directBasis":["ガス事業法第160条第1項"],"basisText":"保安業務規程は事業開始前に届け出る。"},{"choiceIndex":1,"verdict":"間違い","directBasis":["同条第4項"],"basisText":"災害時例外なく、事業者及び従業者は保安業務規程を守る。"},{"choiceIndex":2,"verdict":"正しい","directBasis":["同条第3項"],"basisText":"経済産業大臣は事業者に保安業務規程変更を命ずることができる。"},{"choiceIndex":3,"verdict":"間違い","directBasis":["ガス事業法施行規則第207条"],"basisText":"事業場ごとに定めるのは保安業務監督者の選任である。"},{"choiceIndex":4,"verdict":"正しい","directBasis":["ガス事業法第160条第2項"],"basisText":"変更時は遅滞なく変更事項を届け出る。"}],"changedFields":[],"result":"reviewed_no_explanation_change_needed","sourceUrls":["https://laws.e-gov.go.jp/law/329AC0000000051","https://laws.e-gov.go.jp/law/345M50000400097"]}
