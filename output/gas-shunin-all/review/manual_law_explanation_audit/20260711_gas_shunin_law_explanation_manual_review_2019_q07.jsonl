{"schemaVersion":"gas-shunin-manual-law-explanation-audit/v1","reviewedAt":"2026-07-11","qualification":"gas-shunin-kou","examYear":2019,"sourceQuestionKey":"gas-shunin:kou:2019:law:q07","questionLabel":"問7","sourceQuestionBodyText":"技術基準で規定されているガス工作物及び付臭措置に関する次の記述のうち、誤っているものはいくつあるか。","sourceFile":"output/gas-shunin-kou/questions_json/2019/00_source/question_2019_firestore_2.json","explanationPatchFile":"output/gas-shunin-kou/questions_json/2019/21_explanationText_added/question_2019_firestore_2.json","sourceCorrectChoiceText":["間違い","間違い","間違い","間違い","間違い"],"patchedCorrectChoiceText":["間違い","間違い","間違い","間違い","間違い"],"correctChoiceTextMatchesSource":true,"choiceReviews":[{"choiceIndex":0,"verdict":"間違い","directBasis":["ガス工作物の技術上の基準を定める省令第17条第1項"],"basisText":"安全弁の対象は最高使用圧力が高圧又は中圧のもの等であり、低圧ではない。"},{"choiceIndex":1,"verdict":"間違い","directBasis":["同省令第18条第1項"],"basisText":"計測又は確認装置の対象は移動式ガス発生設備を除く。"},{"choiceIndex":2,"verdict":"間違い","directBasis":["同省令第19条"],"basisText":"警報装置の対象は移動式ガス発生設備を除く。"},{"choiceIndex":3,"verdict":"間違い","directBasis":["同省令第21条"],"basisText":"保安上重要な設備の停電対策に特定製造所の例外はない。"},{"choiceIndex":4,"verdict":"間違い","directBasis":["同省令第22条第1項"],"basisText":"中圧以上のガス圧力により大口供給の用に供するものは付臭義務の例外である。"}],"changedFields":["explanationText[4]"],"result":"explanation_refined","sourceUrls":["https://laws.e-gov.go.jp/law/412M50000400111"]}
