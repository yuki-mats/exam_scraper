{"schemaVersion":"gas-shunin-manual-law-explanation-audit/v1","reviewedAt":"2026-07-11","qualification":"gas-shunin-kou","examYear":2019,"sourceQuestionKey":"gas-shunin:kou:2019:law:q16","questionLabel":"問16","sourceQuestionBodyText":"「特定ガス消費機器の設置工事の監督に関する法律」等に関する次の記述のうち、正しいものはいくつあるか。","sourceFile":"output/gas-shunin-kou/questions_json/2019/00_source/question_2019_firestore_2.json","explanationPatchFile":"output/gas-shunin-kou/questions_json/2019/21_explanationText_added/question_2019_firestore_2.json","sourceCorrectChoiceText":["正しい","正しい","正しい","間違い","間違い"],"patchedCorrectChoiceText":["正しい","正しい","正しい","間違い","間違い"],"correctChoiceTextMatchesSource":true,"choiceReviews":[{"choiceIndex":0,"verdict":"正しい","directBasis":["特定ガス消費機器の設置工事の監督に関する法律第2条第2項"],"basisText":"特定工事は特定ガス消費機器の設置又は変更工事から省令の軽微なものを除く。"},{"choiceIndex":1,"verdict":"正しい","directBasis":["同法第5条第3項"],"basisText":"実地監督者は資格証を、液化石油ガス設備士は免状を携帯する。"},{"choiceIndex":2,"verdict":"正しい","directBasis":["同法第5条第2項"],"basisText":"特定工事従事者は実地監督者の必要な指示に従う。"},{"choiceIndex":3,"verdict":"間違い","directBasis":["同法第6条"],"basisText":"表示は特定ガス消費機器に接続する配管でなく、特定ガス消費機器の見やすい場所に付す。"},{"choiceIndex":4,"verdict":"間違い","directBasis":["同法第7条"],"basisText":"大臣は特定工事事業者に施工に関する報告をさせることができ、立入検査権ではない。"}],"changedFields":[],"result":"reviewed_no_explanation_change_needed","sourceUrls":["https://laws.e-gov.go.jp/law/354AC0000000033","https://laws.e-gov.go.jp/law/354M50000400077"]}
