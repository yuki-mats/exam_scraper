{"schemaVersion":"gas-shunin-manual-law-explanation-audit/v1","reviewedAt":"2026-07-11","qualification":"gas-shunin-kou","examYear":2024,"sourceQuestionKey":"gas-shunin:kou:2024:law:q01","questionLabel":"問1","sourceFile":"output/gas-shunin-kou/questions_json/2024/00_source/question_2024_gassyunin_site_1.json","explanationPatchFile":"output/gas-shunin-kou/questions_json/2024/21_explanationText_added/question_2024_gassyunin_site_1_explanationText_added.json","sourceCorrectChoiceText":["正しい","間違い","正しい","正しい","正しい"],"patchedCorrectChoiceText":["正しい","間違い","正しい","正しい","正しい"],"correctChoiceTextMatchesSource":true,"choiceReviews":[{"choiceIndex":0,"verdict":"正しい","directBasis":["ガス事業法第2条第11項"],"basisText":"ガス事業は、ガス小売事業、一般ガス導管事業、特定ガス導管事業及びガス製造事業をいう。"},{"choiceIndex":1,"verdict":"間違い","directBasis":["ガス事業法第3条第1項"],"basisText":"ガス小売事業を営もうとする者は、経済産業大臣の登録を受けなければならない。"},{"choiceIndex":2,"verdict":"正しい","directBasis":["ガス事業法第2条第1項"],"basisText":"小売供給は一般の需要に応じ導管によりガスを供給することであり、特定ガス発生設備による供給は一の団地内の供給地点数が70以上のものに限る。"},{"choiceIndex":3,"verdict":"正しい","directBasis":["ガス事業法第2条第5項","ガス事業法施行規則第3条第1項第1号"],"basisText":"一般ガス導管事業から省令要件に該当する導管による供給を除き、その導管に12A及び13A以外のガスグループに属するガスを供給する導管を含める。"},{"choiceIndex":4,"verdict":"正しい","directBasis":["ガス事業法第2条第9項"],"basisText":"ガス製造事業は、自ら維持・運用する液化ガス貯蔵設備等を用いてガスを製造する事業で、その設備が経済産業省令の要件に該当するものをいう。"}],"changedFields":["explanationText","suggestedQuestionDetails","sourceExplanationCommonSummary","sourceExplanationChoiceSnippets"],"result":"reviewed_and_rewritten","sourceUrls":["https://laws.e-gov.go.jp/law/329AC0000000051","https://laws.e-gov.go.jp/law/345M50000400097"]}
{"schemaVersion":"gas-shunin-manual-law-explanation-audit/v1","reviewedAt":"2026-07-11","qualification":"gas-shunin-kou","examYear":2024,"sourceQuestionKey":"gas-shunin:kou:2024:law:q02","questionLabel":"問2","sourceFile":"output/gas-shunin-kou/questions_json/2024/00_source/question_2024_gassyunin_site_1.json","explanationPatchFile":"output/gas-shunin-kou/questions_json/2024/21_explanationText_added/question_2024_gassyunin_site_1_explanationText_added.json","sourceCorrectChoiceText":["正しい","間違い","間違い","正しい","間違い"],"patchedCorrectChoiceText":["正しい","間違い","間違い","正しい","間違い"],"correctChoiceTextMatchesSource":true,"choiceReviews":[{"choiceIndex":0,"verdict":"正しい","directBasis":["ガス事業法第13条第1項"],"basisText":"正当な理由がある場合を除き、必要な供給能力を確保しなければならない。"},{"choiceIndex":1,"verdict":"間違い","directBasis":["ガス事業法第14条第1項"],"basisText":"小売供給契約の締結等の際は、料金その他の供給条件を相手方に説明しなければならず、届出ではない。"},{"choiceIndex":2,"verdict":"間違い","directBasis":["ガス事業法第48条第1項"],"basisText":"託送供給約款は定めた上で経済産業大臣の認可を受けなければならず、届出ではない。"},{"choiceIndex":3,"verdict":"正しい","directBasis":["ガス事業法第51条第1項"],"basisText":"最終保障供給約款を定め、経済産業省令で定めるところにより経済産業大臣へ届け出なければならない。"},{"choiceIndex":4,"verdict":"間違い","directBasis":["ガス事業法第56条第1項"],"basisText":"供給計画は作成して年度開始前等に経済産業大臣へ届け出なければならず、認可ではない。"}],"changedFields":["explanationText","suggestedQuestionDetails","sourceExplanationCommonSummary","sourceExplanationChoiceSnippets"],"result":"reviewed_and_rewritten","sourceUrls":["https://laws.e-gov.go.jp/law/329AC0000000051"]}
{"schemaVersion":"gas-shunin-manual-law-explanation-audit/v1","reviewedAt":"2026-07-11","qualification":"gas-shunin-kou","examYear":2024,"sourceQuestionKey":"gas-shunin:kou:2024:law:q03","questionLabel":"問3","sourceFile":"output/gas-shunin-kou/questions_json/2024/00_source/question_2024_gassyunin_site_1.json","explanationPatchFile":"output/gas-shunin-kou/questions_json/2024/21_explanationText_added/question_2024_gassyunin_site_1_explanationText_added.json","sourceCorrectChoiceText":["間違い","間違い","間違い","間違い","正しい"],"patchedCorrectChoiceText":["間違い","間違い","間違い","間違い","正しい"],"correctChoiceTextMatchesSource":true,"choiceReviews":[{"choiceIndex":0,"verdict":"間違い","directBasis":["ガス事業法第61条第2項"],"basisText":"技術基準不適合への修理等の命令又は使用制限は一般ガス導管事業者に対して行う。"},{"choiceIndex":1,"verdict":"間違い","directBasis":["ガス事業法第64条第1項"],"basisText":"保安規程は事業又は所定の工事の開始前に届け出なければならない。"},{"choiceIndex":2,"verdict":"間違い","directBasis":["ガス事業法第64条第3項"],"basisText":"保安規程の変更命令はガス工作物の保安確保のため必要な場合に行う。"},{"choiceIndex":3,"verdict":"間違い","directBasis":["ガス事業法施行規則第92条第1項"],"basisText":"保安規程はガス工作物の工事・維持・運用に関する事項を定めるもので、消費機器の周知・調査は列挙されていない。"},{"choiceIndex":4,"verdict":"正しい","directBasis":["ガス事業法第62条第1項"],"basisText":"他者所有又は占有のガス工作物への維持措置に、所有者又は占有者は協力するよう努めなければならない。"}],"changedFields":["explanationText","suggestedQuestionDetails","sourceExplanationCommonSummary","sourceExplanationChoiceSnippets"],"result":"reviewed_and_rewritten","sourceUrls":["https://laws.e-gov.go.jp/law/329AC0000000051","https://laws.e-gov.go.jp/law/345M50000400097"]}
{"schemaVersion":"gas-shunin-manual-law-explanation-audit/v1","reviewedAt":"2026-07-11","qualification":"gas-shunin-kou","examYear":2024,"sourceQuestionKey":"gas-shunin:kou:2024:law:q04","questionLabel":"問4","sourceFile":"output/gas-shunin-kou/questions_json/2024/00_source/question_2024_gassyunin_site_1.json","explanationPatchFile":"output/gas-shunin-kou/questions_json/2024/21_explanationText_added/question_2024_gassyunin_site_1_explanationText_added.json","sourceCorrectChoiceText":["正しい","間違い","正しい","正しい","間違い"],"patchedCorrectChoiceText":["正しい","間違い","正しい","正しい","間違い"],"correctChoiceTextMatchesSource":true,"choiceReviews":[{"choiceIndex":0,"verdict":"正しい","directBasis":["ガス関係報告規則第4条第1項表第5号"],"basisText":"ガス工作物を操作することにより酸素欠乏症となった事故は速報及び詳報の対象である。"},{"choiceIndex":1,"verdict":"間違い","directBasis":["ガス関係報告規則第4条第1項表第7号"],"basisText":"速報及び詳報の対象は供給支障戸数100以上500未満であり、20戸は含まれない。"},{"choiceIndex":2,"verdict":"正しい","directBasis":["ガス関係報告規則第4条第1項表第8号"],"basisText":"製造支障時間10時間以上24時間未満の製造支障事故は速報及び詳報の対象である。"},{"choiceIndex":3,"verdict":"正しい","directBasis":["ガス関係報告規則第4条第1項表第12号"],"basisText":"ガス工作物からのガス漏えいによる爆発又は火災事故は、所定の除外を除き速報及び詳報の対象である。"},{"choiceIndex":4,"verdict":"間違い","directBasis":["ガス関係報告規則第4条第1項表第18号"],"basisText":"死傷なしの消費機器損傷物損事故の報告方式は詳報のみである。"}],"changedFields":["explanationText","suggestedQuestionDetails","sourceExplanationCommonSummary","sourceExplanationChoiceSnippets"],"result":"reviewed_and_rewritten","sourceUrls":["https://laws.e-gov.go.jp/law/429M60000400016"]}
