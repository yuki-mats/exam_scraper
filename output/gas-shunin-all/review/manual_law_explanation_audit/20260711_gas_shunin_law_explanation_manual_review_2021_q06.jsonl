{"schemaVersion":"gas-shunin-manual-law-explanation-audit/v1","reviewedAt":"2026-07-11","qualification":"gas-shunin-kou","examYear":2021,"sourceQuestionKey":"gas-shunin:kou:2021:law:q06","questionLabel":"問6","sourceQuestionBodyText":"法令で規定されている工事計画及び使用前検査に関する次の記述のうち、誤っているものはいくつあるか。","sourceFile":"output/gas-shunin-kou/questions_json/2021/00_source/question_2021_firestore_2.json","explanationPatchFile":"output/gas-shunin-kou/questions_json/2021/21_explanationText_added/question_2021_firestore_2_explanationText_added.json","sourceCorrectChoiceText":["正しい","間違い","間違い","正しい","正しい"],"patchedCorrectChoiceText":["正しい","間違い","間違い","正しい","正しい"],"correctChoiceTextMatchesSource":true,"choiceReviews":[{"choiceIndex":0,"verdict":"正しい","directBasis":["ガス事業法第101条第1項"],"basisText":"所定工事は計画を届け出るが、非常時のやむを得ない一時的工事は除かれる。"},{"choiceIndex":1,"verdict":"間違い","directBasis":["同条第3項"],"basisText":"届出が受理された日から30日後でなければ工事を開始できない。"},{"choiceIndex":2,"verdict":"間違い","directBasis":["同法第102条第1項"],"basisText":"対象工事では自主検査と登録を受けた者の検査への合格を求める。"},{"choiceIndex":3,"verdict":"正しい","directBasis":["施行規則第153条第1項・別表第一"],"basisText":"所定の高圧化を伴うガス発生器の改造は届出対象である。"},{"choiceIndex":4,"verdict":"正しい","directBasis":["同項・別表第一"],"basisText":"所定の高圧化を伴う整圧器の改造は届出対象である。"}],"changedFields":["explanationText","sourceExplanationCommonSummary"],"result":"reviewed_and_rewritten","sourceUrls":["https://laws.e-gov.go.jp/law/329AC0000000051","https://laws.e-gov.go.jp/law/345M50000400097"]}
