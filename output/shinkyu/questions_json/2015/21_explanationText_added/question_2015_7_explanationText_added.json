    ],
    "suggestedQuestionDetails": [
      {
        "question": "施灸部の化膿を防ぐには何を行うか。",
        "answer": "施灸部の消毒を行う。"
      },
      {
        "question": "灸痕の感染予防で重要なことは何か。",
        "answer": "清潔操作と消毒を徹底する。"
      },
      {
        "question": "水疱ができたときに避けるべき処置は何か。",
        "answer": "排液や掻破を安易に行わないことである。"
      }
