{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "answerMappingMatched",
    "explanationScore",
    "criticalIssues",
    "summary",
    "choiceEvaluations",
    "reworkItems"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["passed", "needs_rework"]
    },
    "answerMappingMatched": {
      "type": "boolean"
    },
    "explanationScore": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "criticalIssues": {
      "type": "array",
      "items": {"type": "string"}
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "choiceEvaluations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["choiceIndex", "verdict", "reason", "evidence"],
        "properties": {
          "choiceIndex": {"type": "integer", "minimum": 0},
          "verdict": {
            "type": "string",
            "enum": ["true", "false", "insufficient_evidence"]
          },
          "reason": {"type": "string", "minLength": 1},
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["source", "locator", "summary"],
              "properties": {
                "source": {"type": "string", "minLength": 1},
                "locator": {"type": "string", "minLength": 1},
                "summary": {"type": "string", "minLength": 1}
              }
            }
          }
        }
      }
    },
    "reworkItems": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["stage", "message", "choiceIndexes"],
        "properties": {
          "stage": {
            "type": "string",
            "enum": ["01", "02", "02a", "02b", "03", "03b"]
          },
          "message": {"type": "string", "minLength": 1},
          "choiceIndexes": {
            "type": "array",
            "items": {"type": "integer", "minimum": 0},
            "uniqueItems": true
          }
        }
      }
    }
  }
}
